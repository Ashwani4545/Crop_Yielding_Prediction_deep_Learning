# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=KrishiAI
APP_ENV=development          # development | production
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true

# ── Model ──────────────────────────────────────────────────────────────────────
MODEL_PATH=models/best_model.keras
SCALER_PATH=models/feature_scaler.pkl
ENCODERS_PATH=models/label_encoders.pkl
METADATA_PATH=models/metadata.json

# ── API Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
BATCH_MAX_SIZE=50

# ── External APIs (optional) ───────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_key_here
AGMARKNET_API_KEY=your_key_here
GOOGLE_EARTH_ENGINE_KEY=your_key_here

# ── Database (for production logging) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/krishiai
# or for SQLite during development:
# DATABASE_URL=sqlite:///logs/predictions.db

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PREDICTIONS=true
PREDICTION_LOG_PATH=logs/predictions.jsonl

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
